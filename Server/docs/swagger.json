        "/api/v2/videos/title": {
            "put": {
                "description": "Updates a given videoID's title",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Updates a videos title",
                "parameters": [
                    {
                        "description": "New Title",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.ChangeVideoTitleRequest"
