            "get": {
                "description": "Gets all the required data for a random video display page",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Get random data for a video",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Video information",
                        "name": "request",
