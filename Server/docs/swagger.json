{
    "swagger": "2.0",
    "info": {
        "description": "API for backing up videos.",
        "title": "WeatherReels",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/v2",
    "paths": {
        "/api/v2/tags/create": {
            "post": {
                "description": "Gets all of the tags associated with a video",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "videos",
                    "tags"
                ],
                "summary": "Get Video's Tags",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Video id",
                        "name": "request",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Tag"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v2/videos/abort": {
            "post": {
                "description": "Gets a group of video and thumbnail urls with the given offset. Max of 10",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Gets a group of video/thumbnail urls",
                "parameters": [
                    {
                        "description": "Video information",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.GetVideoGroupRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.GetVideoGroupResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/models.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v2/videos/description": {
            "put": {
                "description": "Updates a given videoID's description",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "summary": "Updates a videos description",
                "parameters": [
                    {
                        "description": "New Title",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.ChangeVideoDescriptionRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
